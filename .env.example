# ============================================================
# Project Jarvis — .env.example
# Copy this to .env and fill in your real credentials.
# NEVER commit .env to version control.
# ============================================================

# ── LLM ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=local-free-mode
# Model used by all agents (Orchestrator overrides per sub-agent)
JARVIS_LLM_MODEL=claude-sonnet-4-20250514
JARVIS_LLM_TEMPERATURE=0.2
JARVIS_LLM_MAX_TOKENS=4096

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
# Collection names
CHROMA_COLLECTION_USER_CONTEXT=user_context
CHROMA_COLLECTION_TASKS=tasks
CHROMA_COLLECTION_CONVERSATIONS=conversations

# ── Gmail ────────────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=./config/gmail_credentials.json
GMAIL_TOKEN_PATH=./config/gmail_token.json
GMAIL_POLL_INTERVAL_SECONDS=60

# ── Twilio / WhatsApp ────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your personal WhatsApp number in E.164 format
TWILIO_WHATSAPP_TO=whatsapp:+91...

# ── Webhook Server ───────────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
# Set a secret token to validate incoming Twilio webhooks
WEBHOOK_SECRET=change-me-to-a-random-string

# ── Docker Sandbox ───────────────────────────────────────────
DOCKER_SANDBOX_IMAGE=python:3.11-slim
DOCKER_SANDBOX_TIMEOUT_SECONDS=30
DOCKER_SANDBOX_MEM_LIMIT=256m
DOCKER_SANDBOX_CPU_QUOTA=50000   # 50% of one core

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/jarvis.log
